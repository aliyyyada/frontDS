yles.logoSub}>автошкола</span>\n        </div>\n\n        <h2 className={styles.title}>Вход</h2>\n\n        <div className={styles.form}>\n          <Input\n            label=\"Номер телефона\"\n            type=\"phone\"\n            value={phone}\n            onChange={(formatted, raw) => { setPhone(formatted); setPhoneRaw(raw); }}\n            placeholder=\"+7 (999) 000-00-00\"\n            error={errors.phone}\n            autoComplete=\"tel\"\n          />\n          <Input\n            label=\"Пароль\"\n            type=\"password\"\n            value={password}\n            onChange={setPassword}\n            placeholder=\"••••••••\"\n            error={errors.password}\n            autoComplete=\"current-password\"\n          />\n\n          {apiError && <div className={styles.apiError}>{apiError}</div>}\n\n          <Button\n            fullWidth\n            variant=\"primary\"\n            size=\"lg\"\n            loading={loading}\n            onClick={handleSubmit}\n          >\n            Войти\n          </Button>\n\n          <div className={styles.links}>\n            <Link to=\"/forgot-password\" className={styles.link}>\n              Забыли пароль?\n            </Link>\n            <Link to=\"/register\" className={styles.link}>\n              Регистрация\n            </Link>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"],"mappings":";;AAAA,OAAOA,KAAK,IAAIC,QAAQ,QAAQ,OAAO;AACvC,SAASC,WAAW,EAAEC,IAAI,QAAQ,kBAAkB;AACpD,OAAOC,MAAM,IAAIC,OAAO,QAAQ,kBAAkB;AAClD,SAASC,OAAO,QAAQ,qBAAqB;AAC7C,SAASC,KAAK,QAAQ,+BAA+B;AACrD,SAASC,eAAe,QAAQ,+BAA+B;AAC/D,SAASC,MAAM,QAAQ,gCAAgC;AACvD,SAASC,WAAW,EAAEC,cAAc,EAAEC,eAAe,QAAQ,mBAAmB;AAChF,OAAOC,MAAM,MAAM,wBAAwB;AAAC,SAAAC,MAAA,IAAAC,OAAA;AAE5C,SAASC,aAAaA,CAAA,EAAG;EACvB,oBACED,OAAA;IAAKE,KAAK,EAAC,IAAI;IAACC,MAAM,EAAC,KAAK;IAACC,OAAO,EAAC,YAAY;IAACC,IAAI,EAAC,MAAM;IAACC,KAAK,EAAC,4BAA4B;IAAAC,QAAA,gBAC9FP,OAAA;MAAMQ,CAAC,EAAC,whDAAwhD;MAACH,IAAI,EAAC,SAAS;MAACI,MAAM,EAAC;IAAS;MAAAC,QAAA,